# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   environment-independent.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you do not want to check it in:
# lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed
# .posts

# pdm
#   Similar to Pipenv, pdm.lock is generally recommended to be committed
.pdm-python
.pdm-build/

# PEP 582; incoming standard for replacing virtualenv, refers to node_modules/
